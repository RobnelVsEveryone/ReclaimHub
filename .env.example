# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (MySQL / XAMPP) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=reclaim_db

# ── Authentication ───────────────────────────────────────────
JWT_SECRET=findit_secret_key_change_this_in_production
JWT_EXPIRES_IN=8h